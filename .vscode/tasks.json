{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build TradeVerse Risk Engine",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++20",
                "-O2",
                "-march=native",
                "-fdiagnostics-color=always",
                "-IC:/msys64/ucrt64/include",
                "${workspaceFolder}/src/cpp/server.cpp",
                "${workspaceFolder}/src/cpp/greeks.cpp",
                "${workspaceFolder}/src/cpp/portfolio.cpp",
                "-o",
                "${workspaceFolder}/build/server.exe",
                "-LC:/msys64/ucrt64/lib",
                "-lzmq",
                "-lpthread"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the C++ risk engine with BSM Greeks + ZMQ"
        }
    ],
    "version": "2.0.0"
}